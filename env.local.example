# Copia este archivo como ".env.local" en la misma carpeta (raíz del proyecto).
# En PowerShell:  Copy-Item env.local.example .env.local
#
# Para migraciones desde tu PC: usa la URL PÚBLICA (host *.rlwy.net).
# NO uses postgres.railway.internal (solo funciona dentro de Railway).

DATABASE_URL=

# Alternativa si Railway solo expone esta variable:
# POSTGRES_URL=

# URL pública del portal (recomendado en Railway para favicon / metadata OG). Ej: https://tu-servicio.up.railway.app
# Si no la pones, en Railway se intenta usar la variable de entorno RAILWAY_PUBLIC_DOMAIN.
# NEXT_PUBLIC_SITE_URL=

# --- Integración mitrabajo.uy ---
# Base del sitio (default https://www2.mitrabajo.uy). Solo si cambia el dominio.
# MITRABAJO_BASE_URL=https://www2.mitrabajo.uy
# Credenciales para descarga automática del Excel del panel supervisor
MITRABAJO_USER=
MITRABAJO_PASS=
# Carpeta destino de los archivos descargados (opcional, default: downloads/mitrabajo)
# MITRABAJO_DOWNLOAD_DIR=

# Playwright (Railway / mismo path que nixpacks.toml). El código ya usa /app/.playwright-browsers si no está definido.
# PLAYWRIGHT_BROWSERS_PATH=/app/.playwright-browsers
